# ── API Keys ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
SERP_API_KEY=...

# ── Model Settings ────────────────────────────────────────
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.1

# ── Rate Limits ───────────────────────────────────────────
