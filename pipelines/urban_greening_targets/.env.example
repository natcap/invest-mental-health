FETCH_RATE_LIMIT=2
LLM_CONCURRENCY=5

# ── Pipeline Settings ────────────────────────────────────
MAX_RETRIES=3
PAGE_CHAR_LIMIT=30000
PDF_CHAR_LIMIT=30000
BATCH_SIZE=10
